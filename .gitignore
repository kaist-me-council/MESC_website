# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code internal
.claude/scheduled_tasks.lock
.env.production

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
dev.db-shm
dev.db-wal

# local sqlite db (may contain tokens/PII — never commit)
dev.db
dev.db.backup-*
prisma/*.db
prisma/dev.db.backup-*

# local machine shell env dump (personal paths, not project config)
.vscode/colcon.env
