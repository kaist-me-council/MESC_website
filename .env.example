# MESC 학생회 웹사이트 환경 변수 예시
# 실제 값은 .env.local (로컬) 또는 Vercel 대시보드 Settings → Environment Variables 에 입력
# .env.local 은 절대 커밋하지 않습니다.

# ── 데이터베이스 ─────────────────────────────────────────────
# 비어 있으면 로컬 SQLite (prisma/dev.db) 로 fallback
DATABASE_URL=""

# ── 관리자 로그인 ────────────────────────────────────────────
# ADMIN_USERNAME/ADMIN_PASSWORD 둘 다 반드시 설정해야 로그인이 동작한다
# (미설정 시 로그인은 전부 거부됨 — 빈 자격증명 우회 방지)
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL=""

# ── 익명 게시판 식별 salt (프로덕션 권장) ───────────────────────
# 미설정이어도 게시판은 동작하나, 추측 가능한 fallback salt 가 쓰여 익명성이
# 약화된다(서버 로그에 경고 1회 출력). 가능한 한 설정 권장.
# 길고 무작위한 값으로 설정: openssl rand -hex 32
ANON_SALT=""

# ── Vercel Blob (사진/파일 업로드) ──────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ── Google Sheets (회비/예산) ────────────────────────────────
GOOGLE_FEE_CSV_URL=""
GOOGLE_BUDGET_CSV_URL=""
NEXT_PUBLIC_BUDGET_SHEET_EMBED_URL=""

# ── Google Calendar (학과 일정) ─────────────────────────────
NEXT_PUBLIC_GOOGLE_CALENDAR_EMBED_URL=""
NEXT_PUBLIC_ICAL_URL=""

# ── Google Drive 행사 사진 동기화 ────────────────────────────
# 1) 공개 폴더 일괄 가져오기용 API 키 (선택 — 기존 Drive 폴더 import 기능에만 사용)
GOOGLE_DRIVE_API_KEY=""

# 2) OAuth 2.0 (필수 — 사이트가 사용자 본인 Drive 에 폴더/사진 자동 생성)
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
#   - Application type: Web application
#   - Authorized redirect URIs:
#       https://mesc-website.vercel.app/api/auth/drive/callback
#       http://localhost:3000/api/auth/drive/callback   (로컬 테스트 시)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# 옵션 — production 도메인이 mesc-website.vercel.app 가 아니거나 커스텀 도메인 사용 시 명시
GOOGLE_OAUTH_REDIRECT_URI=""
