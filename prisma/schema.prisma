generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String   @default("공지")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  category    String   @default("기타")
  courseCode  String?
  createdAt   DateTime @default(now())
}

model BudgetItem {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  amount      Int
  type        String
  category    String   @default("기타")
  receiptUrl  String?
  createdAt   DateTime @default(now())
}

model Member {
  id       Int     @id @default(autoincrement())
  name     String
  role     String
  bureau   String  @default("")
  council  Boolean @default(false)
  imageUrl String?
  order    Int     @default(0)
}

model Course {
  id                Int     @id @default(autoincrement())
  code              String  @unique
  name              String
  level             String  @default("기타")
  description       String?
  textbook          String?
  textbookAvailable Boolean @default(false)
  youtubeUrl        String?
  order             Int     @default(0)
}

model Event {
  id            Int             @id @default(autoincrement())
  title         String
  date          DateTime
  description   String?
  coverImage    String?
  createdAt     DateTime        @default(now())
  driveFolderId String?         @unique
  lastSyncedAt  DateTime?
  photos        EventPhoto[]
  feedbacks     EventFeedback[]
}

model EventPhoto {
  id          Int     @id @default(autoincrement())
  eventId     Int
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  order       Int     @default(0)
  source      String  @default("blob")
  driveFileId String? @unique
}

model EventFeedback {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  content   String
  rating    Int      @default(3)
  createdAt DateTime @default(now())
}

model SnackWish {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
}

// 홈화면 자동 팝업 설정 (단일 행)
model PopupSettings {
  id        Int      @id @default(1)
  enabled   Boolean  @default(false)
  title     String   @default("기계공학과 학생회")
  message   String?
  updatedAt DateTime @updatedAt
}

// 팝업에 표시할 링크
model PopupLink {
  id        Int      @id @default(autoincrement())
  label     String
  labelEn   String?
  url       String
  icon      String?
  order     Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// 학과 건물
model Building {
  id          Int             @id @default(autoincrement())
  code        String          @unique
  name        String
  nameEn      String?
  description String?
  order       Int             @default(0)
  isExternal  Boolean         @default(false) // 별관·PP동 같은 외부 부속 건물
  floors      BuildingFloor[]
  professors  Professor[]
}

// 층별 평면도
model BuildingFloor {
  id           Int         @id @default(autoincrement())
  buildingId   Int
  building     Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  level        Int
  imageUrl     String?
  description  String?
  width        Int?        // 평면도 픽셀 폭 (좌표 정규화 기준)
  height       Int?
  imageWidth   Int?        // 업로드 이미지/SVG 자연 너비 (FloorMapViewer 용)
  imageHeight  Int?        // 업로드 이미지/SVG 자연 높이 (FloorMapViewer 용)
  svgContent   String?     // 인라인 SVG (raw XML) — DWG/PDF 변환 SVG 그대로 저장
  regionsJson  String?     // 방 다각형 영역 JSON { rooms: [{id, polygon, label?}] }
  graphJson    String?     // 길찾기 그래프 JSON { nodes: [...], edges: [...] }
  driveFileId  String?     // Drive 업로드 시 ID
  professors   Professor[]
  rooms        Room[]
  @@unique([buildingId, level])
}

// 호실
//   code  예: "2305" (전체) 또는 "별관-101"
//   wing  N7 안에서 1~5 (1100번대~1500번대) — 외부 건물은 null
model Room {
  id          Int            @id @default(autoincrement())
  floorId     Int
  floor       BuildingFloor  @relation(fields: [floorId], references: [id], onDelete: Cascade)
  code        String
  wing        Int?
  name        String?
  posX        Float?         // 평면도 위 핀 좌표 (선택)
  posY        Float?
  order       Int            @default(0)
  professors  Professor[]
  @@unique([floorId, code])
  @@index([floorId, wing])
}

// Google Drive OAuth 연결 정보 (단일 행 — id 1 고정)
// 사이트가 사용자 본인 Drive 에 행사 폴더/사진을 자동 생성·업로드하기 위한 refresh token 보관소
model DriveAuth {
  id             Int      @id @default(1)
  refreshToken   String
  parentFolderId String?  // 기본 부모 폴더(예: "학생회 사이트 DB > 갤러리") ID
  scope          String
  email          String?  // 인증한 계정 이메일 (참고용)
  updatedAt      DateTime @updatedAt
}

// 교수님 오피스 정보
model Professor {
  id           Int            @id @default(autoincrement())
  name         String
  nameEn       String?
  title        String         @default("교수")
  buildingId   Int?
  building     Building?      @relation(fields: [buildingId], references: [id])
  floorId      Int?
  floor        BuildingFloor? @relation(fields: [floorId], references: [id])
  roomNumber   String?
  email        String?
  phone        String?
  researchArea String?
  websiteUrl   String?
  imageUrl     String?
  order        Int            @default(0)
  posX         Float?         // 0~1 정규화 좌표 (평면도 위 핀 위치)
  posY         Float?
  roomId       Int?
  room         Room?          @relation(fields: [roomId], references: [id])
}

// 익명 건의함
model Suggestion {
  id          Int       @id @default(autoincrement())
  category    String    @default("기타")
  content     String
  contactInfo String?
  response    String?
  respondedAt DateTime?
  hidden      Boolean   @default(false)
  ipHash      String?
  reportCount Int       @default(0)
  createdAt   DateTime  @default(now())
  @@index([hidden, createdAt])
}

// 익명 자유게시판 게시글
model Post {
  id           Int       @id @default(autoincrement())
  category     String    @default("자유")
  title        String
  content      String
  authorTag    String
  hidden       Boolean   @default(false)
  reportCount  Int       @default(0)
  commentCount Int       @default(0)
  ipHash       String?
  createdAt    DateTime  @default(now())
  comments     Comment[]
  @@index([hidden, createdAt])
}

// 게시글 댓글
model Comment {
  id          Int      @id @default(autoincrement())
  postId      Int
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  content     String
  authorTag   String
  hidden      Boolean  @default(false)
  reportCount Int      @default(0)
  ipHash      String?
  createdAt   DateTime @default(now())
  @@index([postId, hidden, createdAt])
}

// 신고
model Report {
  id         Int      @id @default(autoincrement())
  targetType String   // "post" | "comment" | "suggestion"
  targetId   Int
  reason     String?
  ipHash     String?
  createdAt  DateTime @default(now())
  @@index([targetType, targetId])
}

// ── 사이트 설정 ──────────────────────────────────────────
// 싱글톤: 운영시간 + 연락처 (PopupSettings 패턴)
model SiteSettings {
  id         Int      @id @default(1)
  locationKo String   @default("N7동 학생회실")
  locationEn String   @default("Student Council Room, N7")
  email      String   @default("kaist.mesc@gmail.com")
  phone      String?
  hoursJson  String?
  updatedAt  DateTime @updatedAt
}

// 리스트: 외부링크·SNS (PopupLink 패턴 + category)
model SiteLink {
  id            Int      @id @default(autoincrement())
  category      String   @default("important") // "important" | "community"
  label         String
  labelEn       String?
  url           String
  description   String?
  descriptionEn String?
  icon          String?
  order         Int      @default(0)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([category, order])
}

// 리스트: 동아리 (Member 패턴)
model Club {
  id           Int      @id @default(autoincrement())
  name         String
  nameEn       String?
  tagKo        String?
  tagEn        String?
  descKo       String
  descEn       String?
  activitiesKo String?
  activitiesEn String?
  url          String?
  urlLabel     String?
  emoji        String?
  colorPreset  String?
  order        Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
}
