generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String   @default("공지")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  category    String   @default("기타")
  courseCode  String?
  createdAt   DateTime @default(now())
}

model BudgetItem {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  amount      Int
  type        String
  category    String   @default("기타")
  receiptUrl  String?
  createdAt   DateTime @default(now())
}

model Member {
  id       Int     @id @default(autoincrement())
  name     String
  role     String
  bureau   String  @default("")
  council  Boolean @default(false)
  imageUrl String?
  order    Int     @default(0)
}

model Course {
  id                Int     @id @default(autoincrement())
  code              String  @unique
  name              String
  level             String  @default("기타")
  description       String?
  textbook          String?
  textbookAvailable Boolean @default(false)
  youtubeUrl        String?
  order             Int     @default(0)
}

model Event {
  id            Int             @id @default(autoincrement())
  title         String
  date          DateTime
  description   String?
  coverImage    String?
  createdAt     DateTime        @default(now())
  driveFolderId String?         @unique
  lastSyncedAt  DateTime?
  photos        EventPhoto[]
  feedbacks     EventFeedback[]
}

model EventPhoto {
  id          Int     @id @default(autoincrement())
  eventId     Int
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  order       Int     @default(0)
  source      String  @default("blob")
  driveFileId String? @unique
}

model EventFeedback {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  content   String
  rating    Int      @default(3)
  createdAt DateTime @default(now())
}

model SnackWish {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
}

// 홈화면 자동 팝업 설정 (단일 행)
model PopupSettings {
  id        Int      @id @default(1)
  enabled   Boolean  @default(false)
  title     String   @default("기계공학과 학생회")
  message   String?
  updatedAt DateTime @updatedAt
}

// 팝업에 표시할 링크
model PopupLink {
  id        Int      @id @default(autoincrement())
  label     String
  labelEn   String?
  url       String
  icon      String?
  order     Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// 학과 건물
model Building {
  id          Int             @id @default(autoincrement())
  code        String          @unique
  name        String
  nameEn      String?
  description String?
  order       Int             @default(0)
  floors      BuildingFloor[]
  professors  Professor[]
}

// 층별 평면도
model BuildingFloor {
  id          Int         @id @default(autoincrement())
  buildingId  Int
  building    Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  level       Int
  imageUrl    String?
  description String?
  professors  Professor[]
  @@unique([buildingId, level])
}

// 교수님 오피스 정보
model Professor {
  id           Int            @id @default(autoincrement())
  name         String
  nameEn       String?
  title        String         @default("교수")
  buildingId   Int?
  building     Building?      @relation(fields: [buildingId], references: [id])
  floorId      Int?
  floor        BuildingFloor? @relation(fields: [floorId], references: [id])
  roomNumber   String?
  email        String?
  phone        String?
  researchArea String?
  websiteUrl   String?
  imageUrl     String?
  order        Int            @default(0)
}
