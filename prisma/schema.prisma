generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String   @default("공지")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  category    String   @default("기타")
  courseCode  String?
  createdAt   DateTime @default(now())
}

model BudgetItem {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  amount      Int
  type        String
  category    String   @default("기타")
  receiptUrl  String?
  createdAt   DateTime @default(now())
}

model Member {
  id       Int     @id @default(autoincrement())
  name     String
  role     String
  bureau   String  @default("")
  council  Boolean @default(false)
  imageUrl String?
  order    Int     @default(0)
}

model Course {
  id                Int     @id @default(autoincrement())
  code              String  @unique
  name              String
  level             String  @default("기타")
  description       String?
  textbook          String?
  textbookAvailable Boolean @default(false)
  youtubeUrl        String?
  order             Int     @default(0)
}

model Event {
  id          Int             @id @default(autoincrement())
  title       String
  date        DateTime
  description String?
  coverImage  String?
  createdAt   DateTime        @default(now())
  photos      EventPhoto[]
  feedbacks   EventFeedback[]
}

model EventPhoto {
  id       Int     @id @default(autoincrement())
  eventId  Int
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl String
  caption  String?
  order    Int     @default(0)
}

model EventFeedback {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  content   String
  rating    Int      @default(3)
  createdAt DateTime @default(now())
}

model SnackWish {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
}
